APP_ENV=production
APP_TITLE=Music Platform Backend
APP_VERSION=1.0.0
SECRET_KEY=changeme-super-secret-key-min-32-chars
ADMIN_API_KEY=changeme-admin-api-key
DATABASE_URL=postgresql://musicuser:changeme-secure-password@postgres:5432/musicdb
DATABASE_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_POOL_TIMEOUT=30
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:5173
DOCS_ENABLED=false
REDOC_ENABLED=false
CORS_ALLOW_CREDENTIALS=false
HTTPS_REDIRECT=false
MAX_UPLOAD_SIZE_BYTES=10485760
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=60

POSTGRES_USER=musicuser
POSTGRES_PASSWORD=changeme-secure-password
POSTGRES_DB=musicdb
REDIS_PASSWORD=changeme-redis-password
REDIS_URL=redis://:changeme-redis-password@redis:6379/0
ND_ADMIN_PASSWORD=changeme-navidrome-password
