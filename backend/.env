# Backend Environment Variables for Testing

# Database
DATABASE_URL=sqlite:///./music_platform.db

# Payment Domain Settings
PAYMENT_ENABLED=true
TELEBIRR_ENABLED=true
CHAPA_ENABLED=true
CBE_BANK_ENABLED=true
MANUAL_BANK_ENABLED=true

# Telebirr Configuration
TELEBIRR_BASE_URL=https://api.telebirr.et
TELEBIRR_APP_ID=test_app_id
TELEBIRR_APP_SECRET=test_app_secret
TELEBIRR_MERCHANT_CODE=test_merchant
TELEBIRR_SHORT_CODE=test
TELEBIRR_TEST_MODE=true

# Chapa Configuration
CHAPA_BASE_URL=https://api.chapa.co
CHAPA_SECRET_KEY=test_secret_key
CHAPA_WEBHOOK_SECRET=test_webhook_secret
CHAPA_MERCHANT_ID=test_merchant_id
CHAPA_TEST_MODE=true

# CBE Bank Configuration
CBE_BANK_BASE_URL=https://api.cbe.com.et
CBE_BANK_API_KEY=test_api_key
CBE_BANK_MERCHANT_ID=test_merchant_id
CBE_BANK_TEST_MODE=true

# Manual Bank Configuration
MANUAL_BANK_ACCOUNT_NUMBER=123456789
MANUAL_BANK_ACCOUNT_NAME=Test Account
MANUAL_BANK_BANK_NAME=Test Bank

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=test_secret_key_for_development_only
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API Settings
DOCS_ENABLED=true
REDOC_ENABLED=true
